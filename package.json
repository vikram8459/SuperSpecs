{
  "name": "@superspecs/cli",
  "version": "0.1.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "Spec-Driven Development (SDD) skills framework, OpenSpec-based. Cursor plugin today; methodology is tool-agnostic.",
  "license": "MIT",
  "author": "SuperSpecs Contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vikram8459/SuperSpecs.git"
  },
  "bugs": {
    "url": "https://github.com/vikram8459/SuperSpecs/issues"
  },
  "homepage": "https://github.com/vikram8459/SuperSpecs#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "type": "module",
  "bin": {
    "superspecs": "./dist/superspecs.js"
  },
  "files": [
    "bin/",
    "dist/",
    "schemas/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "eval": "node dist/superspecs.js eval",
    "release": "powershell -ExecutionPolicy Bypass -File scripts/release.ps1"
  },
  "dependencies": {
    "ajv": "^8.12.0",
    "commander": "^12.0.0",
    "fast-glob": "^3.3.2",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.4",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.4",
    "json-schema-to-typescript": "^14.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.61.0",
    "vitest": "^3.2.4"
  }
}
